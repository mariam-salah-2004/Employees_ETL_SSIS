                              name="Expression">(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DT_DBDATE)age</property>

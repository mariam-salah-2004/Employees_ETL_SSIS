                          dataType="i4"
                          errorOrTruncationOperation="Computation"
                          errorRowDisposition="FailComponent"
                          lineageId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[date_key]"
                          name="date_key"
                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">(DT_I4)([YEAR]((DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) * 10000 + [MONTH]((DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) * 100 + [DAY]((DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}))</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DT_I4)(YEAR((DT_DBDATE)age) * 10000 + MONTH((DT_DBDATE)age) * 100 + DAY((DT_DBDATE)age))</property>

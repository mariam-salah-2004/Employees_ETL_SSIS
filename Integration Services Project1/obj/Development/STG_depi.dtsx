                          lineageId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[quarter]"
                          name="quarter"
                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">(DT_I4)([MONTH]((DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) - 1) / 3 + 1</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DT_I4)(MONTH((DT_DBDATE)age) - 1) / 3 + 1</property>
                          </properties>
                        </outputColumn>
                        <outputColumn
                          refId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[is_holiday]"
                          dataType="i4"
                          errorOrTruncationOperation="Computation"
                          errorRowDisposition="FailComponent"
                          lineageId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[is_holiday]"
                          name="is_holiday"
                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">([DATEPART]("mm",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 1 &amp;&amp; [DATEPART]("dd",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 1) || ([DATEPART]("mm",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 5 &amp;&amp; [DATEPART]("dd",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 1) || ([DATEPART]("mm",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 3 &amp;&amp; [DATEPART]("dd",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 8) ? 1 : 0</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DATEPART("mm",(DT_DATE)age) == 1 &amp;&amp; DATEPART("dd",(DT_DATE)age) == 1) || (DATEPART("mm",(DT_DATE)age) == 5 &amp;&amp; DATEPART("dd",(DT_DATE)age) == 1) || (DATEPART("mm",(DT_DATE)age) == 3 &amp;&amp; DATEPART("dd",(DT_DATE)age) == 8) ? 1 : 0</property>
                          </properties>
                        </outputColumn>
                        <outputColumn
                          refId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[day_week]"

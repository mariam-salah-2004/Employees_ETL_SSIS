                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">[DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 1 ? "January" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 2 ? "February" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 3 ? "March" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 4 ? "April" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 5 ? "May" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 6 ? "June" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 7 ? "July" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 8 ? "August" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 9 ? "September" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 10 ? "October" : [DATEPART]("mm",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 11 ? "November" : "December"</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">DATEPART("mm",(DT_DBDATE)age) == 1 ? "January" : DATEPART("mm",(DT_DBDATE)age) == 2 ? "February" : DATEPART("mm",(DT_DBDATE)age) == 3 ? "March" : DATEPART("mm",(DT_DBDATE)age) == 4 ? "April" : DATEPART("mm",(DT_DBDATE)age) == 5 ? "May" : DATEPART("mm",(DT_DBDATE)age) == 6 ? "June" : DATEPART("mm",(DT_DBDATE)age) == 7 ? "July" : DATEPART("mm",(DT_DBDATE)age) == 8 ? "August" : DATEPART("mm",(DT_DBDATE)age) == 9 ? "September" : DATEPART("mm",(DT_DBDATE)age) == 10 ? "October" : DATEPART("mm",(DT_DBDATE)age) == 11 ? "November" : "December"</property>

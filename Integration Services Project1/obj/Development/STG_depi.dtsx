                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">([DATEPART]("dw",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 6 || [DATEPART]("dw",(DT_DATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 7) ? 1 : 0</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DATEPART("dw",(DT_DATE)age) == 6 || DATEPART("dw",(DT_DATE)age) == 7) ? 1 : 0</property>
                          </properties>
                        </outputColumn>
                        <outputColumn
                          refId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[day_name]"
                          dataType="wstr"
                          errorOrTruncationOperation="Computation"
                          errorRowDisposition="FailComponent"
                          length="9"
                          lineageId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[day_name]"
                          name="day_name"
                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">[DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 1 ? "Sunday" : [DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 2 ? "Monday" : [DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 3 ? "Tuesday" : [DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 4 ? "Wednesday" : [DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 5 ? "Thursday" : [DATEPART]("dw",(DT_DBDATE)#{Package\Sequence Container\dim_date\OLE DB Source.Outputs[OLE DB Source Output].Columns[age]}) == 6 ? "Friday" : "Saturday"</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">DATEPART("dw",(DT_DBDATE)age) == 1 ? "Sunday" : DATEPART("dw",(DT_DBDATE)age) == 2 ? "Monday" : DATEPART("dw",(DT_DBDATE)age) == 3 ? "Tuesday" : DATEPART("dw",(DT_DBDATE)age) == 4 ? "Wednesday" : DATEPART("dw",(DT_DBDATE)age) == 5 ? "Thursday" : DATEPART("dw",(DT_DBDATE)age) == 6 ? "Friday" : "Saturday"</property>
                          </properties>
                        </outputColumn>
                        <outputColumn
                          refId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[month_name]"
                          dataType="wstr"
                          errorOrTruncationOperation="Computation"
                          errorRowDisposition="FailComponent"
                          length="9"
                          lineageId="Package\Sequence Container\dim_date\Derived Column.Outputs[Derived Column Output].Columns[month_name]"
